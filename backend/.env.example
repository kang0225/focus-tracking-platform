GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
GOOGLE_REDIRECT_URI=
APP_URL=

# PostgreSQL (RDS). Drizzle & app share this.
# Example: postgres://<user>:<password>@<host>:5432/<db>?sslmode=require
DATABASE_URL=

# Optional pool tuning
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_MS=30000

# Redis (ElastiCache)
REDIS_HOST=10.0.11.0
REDIS_PORT=6379
REDIS_STREAM_MAXLEN=10800

ML_SERVICE_URL=http://ml-service:8000

# WebRTC ICE servers for cross-network video calls.
# Add a TURN server in production so users behind restrictive NATs can relay media.
# Example: [{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
NEXT_PUBLIC_RTC_ICE_SERVERS=
