
######################
### CloudFront 배포 ###
######################

locals {
  s3_origin_id = "${var.project_name}-s3-origin"
  alb_origin_id = "${var.project_name}-alb-origin"
}

##############################################
### CloudFront Origin Access Control (OAC) ###
##############################################
# CloudFront만 S3 접근 허용
resource "aws_cloudfront_origin_access_control" "this" {
  name                              = "${var.project_name}-oac"
  description                       = "OAC for ${var.project_name} S3 bucket"
  origin_access_control_origin_type = "s3"
  signing_behavior                  = "always"
  signing_protocol                  = "sigv4"
}

###########################
### CloudFront 캐싱 정책 ###
###########################
data "aws_cloudfront_cache_policy" "caching_optimized" {
  name = "Managed-CachingOptimized"
} # 캐싱 활성화

data "aws_cloudfront_cache_policy" "caching_disabled" {
  name = "Managed-CachingDisabled"
} # 캐싱 비활성화

/*
#############################################################
### CloudFront Response Headers Policy (Security Headers) ###
#############################################################
resource "aws_cloudfront_response_headers_policy" "security_headers" {
  name    = "${var.project_name}-security-headers"
  comment = "Security headers policy for ${var.project_name}"

  security_headers_config {
    content_type_options {
      override = true
    }

    frame_options {
      frame_option = "DENY"
      override     = true
    }

    referrer_policy {
      referrer_policy = "strict-origin-when-cross-origin"
      override        = true
    }

    strict_transport_security {
      access_control_max_age_sec = 31536000
      include_subdomains         = true
      preload                    = true
      override                   = true
    }

    xss_protection {
      mode_block = true
      protection = true
      override   = true
    }
  }
}
*/

###########################
### CloudFront 배포 요청 ###
###########################
resource "aws_cloudfront_distribution" "this" {
  enabled             = true
  is_ipv6_enabled     = true
  default_root_object = var.default_root_object
  price_class         = "PriceClass_200" # 한국 전용 (비용은 트래픽 양에 따라 청구지만 미미)
  aliases             = var.domain_aliases # 커스텀 도메인 목록

  #####################
  ### S3 origin 설정 ###
  #####################
  # 정적 파일 요청은 S3에서 처리
  origin {
    domain_name              = aws_s3_bucket.this.bucket_regional_domain_name
    origin_id                = local.s3_origin_id
    origin_access_control_id = aws_cloudfront_origin_access_control.this.id

    origin_shield {
      enabled              = false
      origin_shield_region = "ap-northeast-2"
    } # 요청 경로에 캐싱을 한 번 더하는 기능인데, 리액트나 정적 파일은 엣지에 캐싱만 해도 충분하여 off
  }

  ######################
  ### ALB origin 설정 ###
  ######################
  # API 요청은 ALB로 전송
  origin {
    domain_name = aws_lb.this.dns_name
    origin_id   = local.alb_origin_id
    
    custom_origin_config {
      http_port              = 80
      https_port             = 443
      origin_protocol_policy = "https-only"
      origin_ssl_protocols   = ["TLSv1.2"]
    }
  }

  ##############################
  ### Default Cache Behavior ###
  ##############################
  # /api/와 /static/으로 오는 요청 외의 모든 요청들을 캐싱
  default_cache_behavior {
    target_origin_id       = local.s3_origin_id
    viewer_protocol_policy = "redirect-to-https"
    allowed_methods        = ["GET", "HEAD", "OPTIONS"]
    cached_methods         = ["GET", "HEAD"]
    compress               = true

    cache_policy_id            = data.aws_cloudfront_cache_policy.caching_optimized.id
    response_headers_policy_id = aws_cloudfront_response_headers_policy.security_headers.id

    function_association {
      event_type   = "viewer-request"
      function_arn = aws_cloudfront_function.url_rewrite.arn
    }
  }

  ###############################
  ### Ordered Cache Behaviors ###
  ###############################
  # React가 /api/로 한 요청은 alb로 전송
  ordered_cache_behavior {
    path_pattern           = "/api/*"
    target_origin_id       = local.alb_origin_id
    viewer_protocol_policy = "https-only"
    allowed_methods        = ["DELETE", "GET", "HEAD", "OPTIONS", "PATCH", "POST", "PUT"]
    cached_methods         = ["GET", "HEAD"]
    compress               = true

    cache_policy_id = data.aws_cloudfront_cache_policy.caching_disabled.id # api 요청은 캐싱을 비활성화 해야 함.
  }

  # React가 /static/로 한 정적 요청은 s3에서 처리
  ordered_cache_behavior {
    path_pattern           = "/static/*"
    target_origin_id       = local.s3_origin_id
    viewer_protocol_policy = "redirect-to-https"
    allowed_methods        = ["GET", "HEAD"]
    cached_methods         = ["GET", "HEAD"]
    compress               = true

    cache_policy_id = data.aws_cloudfront_cache_policy.caching_optimized.id

    min_ttl     = 86400 # 최소 1일
    default_ttl = 300800
    max_ttl     = 604800 # 최대 7일
  }

  # ----------------------------------------------------------
  # Custom Error Responses (SPA 라우팅 지원)
  # ----------------------------------------------------------
  custom_error_response {
    error_code            = 403
    response_code         = 200
    response_page_path    = "/index.html"
    error_caching_min_ttl = 10
  }

  custom_error_response {
    error_code            = 404
    response_code         = 200
    response_page_path    = "/index.html"
    error_caching_min_ttl = 10
  }

  ################
  ### 지역 제한 ###
  ################
  restrictions {
    geo_restriction {
      restriction_type = "whitelist"  # 화이트리스트 방식
      locations        = ["KR"]       # 한국만 허용
    }
  }

  

  # ----------------------------------------------------------
  # SSL/TLS Certificate
  # ----------------------------------------------------------
  viewer_certificate {
    acm_certificate_arn            = var.acm_certificate_arn != "" ? var.acm_certificate_arn : null
    cloudfront_default_certificate = var.acm_certificate_arn == "" ? true : false
    ssl_support_method             = var.acm_certificate_arn != "" ? "sni-only" : null
    minimum_protocol_version       = var.acm_certificate_arn != "" ? "TLSv1.2_2021" : null
  }

  # ----------------------------------------------------------
  # Logging
  # ----------------------------------------------------------
  dynamic "logging_config" {
    for_each = var.enable_access_logs ? [1] : []
    content {
      include_cookies = false
      bucket          = "${aws_s3_bucket.logs[0].bucket_domain_name}"
      prefix          = "cloudfront/"
    }
  }

  tags = merge(var.tags, {
    Name = "${var.project_name}-cloudfront"
  })

  depends_on = [
    aws_cloudfront_origin_access_control.this,
    aws_cloudfront_response_headers_policy.security_headers,
  ]
}

# ------------------------------------------------------------
# CloudFront Function (URL Rewrite - SPA 지원)
# ------------------------------------------------------------
resource "aws_cloudfront_function" "url_rewrite" {
  name    = "${var.project_name}-url-rewrite"
  runtime = "cloudfront-js-2.0"
  comment = "Rewrite URLs for SPA routing"
  publish = true

  code = <<-EOT
    async function handler(event) {
      const request = event.request;
      const uri = request.uri;

      // 파일 확장자가 없는 경우 index.html로 리다이렉트
      if (!uri.includes('.')) {
        request.uri = '/index.html';
      }

      return request;
    }
  EOT
}

# ------------------------------------------------------------
# S3 Bucket Policy (CloudFront OAC 접근 허용)
# ------------------------------------------------------------
resource "aws_s3_bucket_policy" "cloudfront_access" {
  bucket = aws_s3_bucket.this.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowCloudFrontOAC"
        Effect = "Allow"
        Principal = {
          Service = "cloudfront.amazonaws.com"
        }
        Action   = "s3:GetObject"
        Resource = "${aws_s3_bucket.this.arn}/*"
        Condition = {
          StringEquals = {
            "AWS:SourceArn" = aws_cloudfront_distribution.this.arn
          }
        }
      }
    ]
  })
}